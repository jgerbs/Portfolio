@* ============================================================
   File:    Views/Account/ForgotPassword.cshtml
   Purpose: Allows users to request a password reset link
            by entering their registered email address.

   Sections:
   1) PAGE SETUP
   2) ERROR ALERT
   3) EMAIL INPUT FORM + BACK LINK
   ============================================================ *@

@* ============================================================
   1) PAGE SETUP
   ============================================================ *@
@{
    ViewData["Title"] = "Forgot Password";
}

<h2>Forgot Password</h2>

@* ============================================================
   2) ERROR ALERT
   ============================================================ *@
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mt-3">@TempData["Error"]</div>
}

@* ============================================================
   3) EMAIL INPUT FORM + BACK LINK
   ============================================================ *@
<form asp-action="ForgotPassword" method="post" class="mt-3">
    <div class="form-group">
        <label>Email</label>
        <input name="email" type="email" class="form-control" required />
    </div>
    <button class="btn btn-primary mt-3">Send Reset Link</button>
</form>

<a asp-action="Login" class="btn btn-link mt-3">Back to Login</a>
