@* ============================================================
   File:    Views/Account/Login.cshtml
   Purpose: Login form with contextual success banners (post-reset,
            post-confirmation) and an inline resend option for users
            who haven't confirmed their email yet.

   Sections:
   1) PAGE SETUP
   2) POST-ACTION SUCCESS BANNERS
   3) VALIDATION ERROR BLOCK + RESEND SHORTCUT
   4) LOGIN FORM
   ============================================================ *@
@model BlogApp.ViewModels.LoginViewModel

@* ============================================================
   1) PAGE SETUP
   ============================================================ *@
@{
    ViewData["Title"] = "Login";
}

<h2>@ViewData["Title"]</h2>
<br />

@* ============================================================
   2) POST-ACTION SUCCESS BANNERS
   Shown after: password reset email sent, email confirmed, or
   password successfully reset.
   ============================================================ *@
@if (TempData["ResetEmailSent"] != null)
{
    <div class="alert alert-success mt-3">@TempData["ResetEmailSent"]</div>
}

@if (TempData["EmailConfirmed"] != null)
{
    <div class="alert alert-success mt-3">@TempData["EmailConfirmed"]</div>
}

@if (TempData["ResetSuccess"] != null)
{
    <div class="alert alert-success mt-3">@TempData["ResetSuccess"]</div>
}

@* ============================================================
   3) VALIDATION ERROR BLOCK + RESEND SHORTCUT
   If the error mentions an unconfirmed email, display an inline
   resend button so the user can recover without navigating away.
   ============================================================ *@
@if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Count > 0))
{
    <div class="alert alert-danger mt-3">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@error.ErrorMessage</div>
        }

        @if (ViewData.ModelState.Values.SelectMany(v => v.Errors)
            .Any(e => e.ErrorMessage.Contains("confirm your email")))
        {
            <hr />
            <form asp-action="ResendConfirmationEmail" method="post" class="d-inline">
                <input type="hidden" name="email" value="@Model.Email" />
                <button class="btn btn-sm btn-outline-primary">Resend Confirmation Email</button>
            </form>
        }
    </div>
}

@* ============================================================
   4) LOGIN FORM
   ============================================================ *@
<form asp-action="Login" method="post">
    <div class="form-group">
        <label for="Email">Email</label>
        <input type="email" class="form-control" id="Email" name="Email"
               value="@Model.Email" required />
    </div>

    <div class="form-group">
        <label for="Password">Password</label>
        <input type="password" class="form-control" id="Password" name="Password" required />
    </div>

    <br />

    <button type="submit" class="btn btn-primary">Login</button>
    <a asp-action="ForgotPassword" class="btn btn-link">Forgot Password?</a>
</form>
